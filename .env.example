# PostgreSQL (obrigatório). Exemplos:
# - Supabase: Project Settings → Database → Connection string (URI)
# - Local: postgresql://postgres:postgres@localhost:5432/gestor_funilaria_backend
DATABASE_URL=postgresql://postgres.iawhefhfdcekkrsqelnp:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# TLS: omita ou use qualquer valor exceto "false" para SSL (Supabase, nuvem).
# Postgres local sem SSL: DATABASE_SSL=false
# DATABASE_SSL=false

# URL base do painel em produção (redirects quando a API não é localhost).
FRONTEND_APP_URL=https://app.funilariavassoler.com.br

# Só desenvolvimento: ao abrir http://localhost:3000/ a API redireciona para o painel (Gestor_Funilaria_Frontend, Vite = 5173).
# FRONTEND_APP_URL_LOCAL=http://localhost:5173

# Porta da API (padrão 3000). EADDRINUSE: encerre o processo na 3000 ou use PORT=3001 e ajuste VITE_API_URL no repositório Gestor_Funilaria_Frontend.
# PORT=3000

# JWT (obrigatório). Gere um segredo longo e aleatório em produção.
JWT_SECRET=

# Opcional: tempo de vida do token (ex.: 7d, 24h, 3600s).
# JWT_EXPIRES_IN=7d

# Credenciais do painel. Usuário padrão se omitido: admin
AUTH_USERNAME=funilariaVassoler

# Senha em texto (apenas desenvolvimento). Em produção prefira hash bcrypt:
AUTH_PASSWORD=V@$$0ler73

# Produção: gere com Node — require('bcrypt').hashSync('sua_senha', 12)
# e defina só isto (sem AUTH_PASSWORD):
# AUTH_PASSWORD_HASH=$2b$12$...

# --- E-mail da agenda (opcional) ---
# Se NOTIFY_EMAIL_TO e SMTP_* estiverem preenchidos:
# - aviso imediato ao cadastrar agendamento
# - resumo diário às 07:00 (America/Sao_Paulo)
# NOTIFY_EMAIL_TO=seu@email.com
# NOTIFY_EMAIL_FROM="Funilaria Vassoler" <seu@email.com>
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seu@gmail.com
# SMTP_PASS=sua_senha_de_app
# Gmail: use "Senha de app" (conta Google → Segurança → Verificação em 2 etapas → Senhas de app).
